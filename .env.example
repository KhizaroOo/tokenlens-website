# ─────────────────────────────────────────────────────────────────────────────
# TokenLens — public website (marketing-only). Copy to .env and fill in.
# NEVER commit a real .env. This example contains placeholders only.
# ─────────────────────────────────────────────────────────────────────────────

# Database — required for lead capture (/api/contact, /api/demo-request persist
# to the ContactSubmission / DemoRequest tables). Use any Postgres (Neon, etc.).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Secret used only as a salt to hash lead-capture IPs (SHA-256). Never stored raw.
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-secure-secret-min-32-chars"

# ── Email notifications (optional) ───────────────────────────────────────────
# If all three are set, new contact/demo leads trigger an email via Resend.
# If any are missing, forms still succeed (rows persist) — the row is flagged
# with notificationError = "missing_config:<which>". No fake delivery.
# RESEND_API_KEY="re_REPLACE_ME"                 # do NOT commit a real key
# EMAIL_FROM="TokenLens <noreply@yourdomain>"    # must be a Resend-verified sender/domain
LEAD_NOTIFICATION_EMAIL="khizar.imtiaz@gmail.com"

# ── Canonical site URL (recommended in production) ───────────────────────────
# Used by robots.txt, sitemap.xml, and OG metadata. No trailing slash.
# NEXT_PUBLIC_SITE_URL="https://www.yourdomain"

# ── Application portal link ──────────────────────────────────────────────────
# The authenticated dashboard lives in a SEPARATE deployment (tokenlens-idea).
# Set this to its origin and /login + /signup link straight to it.
# NEXT_PUBLIC_PORTAL_URL="https://app.yourdomain"

NODE_ENV="development"
